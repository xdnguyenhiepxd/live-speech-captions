# macOS — CPU (Mac Intel). Một file cho mọi engine.
#   cp config/mac-cpu.ini.example config.ini
#
# Chọn engine trong app (tab «Nhận giọng») hoặc sửa backend bên dưới:
#   whisper = local (mặc định) | mlx = không dùng trên Intel
#   deepgram = realtime streaming (khuyến nghị) | openai/gemini = cloud batch
# API key: tab «Cloud API» hoặc điền [api] (không commit lên git).
# YouTube: BlackHole — BLACKHOLE_SETUP.md

[display]
reader_font_size = 32
reader_window_width = 920
reader_keep_lines = 50

[transcription]
backend = whisper
whisper_model = distil-small.en
device = cpu
compute_type = int8
source_language = en
beam_size = 1
cpu_threads = 4
vad_filter = false
max_transcribe_seconds = 8.0
log_latency = true
use_context_prompt = true
cloud_partial = false
cloud_min_request_interval = 13.0
realtime_mode = true

[api]
deepgram_api_key =
deepgram_model = nova-3
deepgram_language = en
openai_api_key =
openai_base_url =
openai_stt_model = gpt-4o-mini-transcribe
gemini_api_key =
gemini_model = gemini-2.5-flash

[audio]
device_index = auto
sample_rate = 16000
silence_threshold = 0.005
silence_duration = 0.55
chunk_duration = 0.1
streaming_step_size = 0.2
max_phrase_duration = 6.0
reader_partial_updates = true
reader_update_interval = 1.0
partial_window_seconds = 2.5
min_phrase_duration = 0.8
standard_cut_duration = 1.0
soft_cut_at_duration = 4.5
