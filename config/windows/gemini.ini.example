# Windows + Google Gemini
# copy config\windows\gemini.ini.example config.ini

[api]
base_url = https://generativelanguage.googleapis.com/v1beta/openai/
api_key = YOUR_GEMINI_API_KEY_HERE

[translation]
model = gemini-2.0-flash
# Phụ đề tiếng Anh: target_lang = English
target_lang = Vietnamese
threads = 4

[display]
display_duration = 10
window_width = 800
window_height = 120

[transcription]
backend = whisper
whisper_model = base
funasr_model = iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch
device = cuda
compute_type = float16
# Nói tiếng Anh: source_language = en
source_language = auto
transcription_workers = 4

[audio]
device_index = auto
sample_rate = 16000
silence_threshold = 0.005
silence_duration = 0.5
chunk_duration = 0.1
max_phrase_duration = 30
streaming_mode = true
streaming_interval = 3
streaming_step_size = 0.2
update_interval = 0.8
streaming_overlap = 0.3
