# Intel — NHANH (tiny.en, câu ngắn — dễ sai / cụt câu)
#   cp config/mac/macbook-air-intel-fast.ini.example config.ini

[display]
reader_font_size = 32
reader_window_width = 920
reader_keep_lines = 50

[transcription]
backend = whisper
whisper_model = tiny.en
device = cpu
compute_type = int8
source_language = en
beam_size = 1
cpu_threads = 2
vad_filter = false
max_transcribe_seconds = 2.0
log_latency = true
use_context_prompt = false

[audio]
device_index = auto
sample_rate = 16000
silence_threshold = 0.005
silence_duration = 0.3
max_phrase_duration = 2.2
reader_partial_updates = false
min_phrase_duration = 0.45
standard_cut_duration = 0.6
soft_cut_at_duration = 1.8
