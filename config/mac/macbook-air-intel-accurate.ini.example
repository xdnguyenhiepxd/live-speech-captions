# Intel — CHÍNH XÁC (chậm hơn, câu dài)
#   cp config/mac/macbook-air-intel-accurate.ini.example config.ini

[display]
reader_font_size = 32
reader_window_width = 920
reader_keep_lines = 50

[transcription]
backend = whisper
whisper_model = small.en
device = cpu
compute_type = int8
source_language = en
beam_size = 1
cpu_threads = 4
vad_filter = false
max_transcribe_seconds = 10.0
log_latency = true
use_context_prompt = true

[audio]
device_index = auto
sample_rate = 16000
silence_threshold = 0.005
silence_duration = 0.6
max_phrase_duration = 8.0
reader_partial_updates = true
reader_update_interval = 1.2
partial_window_seconds = 3.0
min_phrase_duration = 1.0
standard_cut_duration = 1.2
soft_cut_at_duration = 5.5
