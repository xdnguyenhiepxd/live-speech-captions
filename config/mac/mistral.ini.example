# macOS + Mistral AI
# cp config/mac/mistral.ini.example config.ini
# API key: https://console.mistral.ai/api-keys/

[api]
base_url = https://api.mistral.ai/v1
api_key = YOUR_MISTRAL_API_KEY_HERE

[translation]
model = mistral-small-latest
# Phụ đề tiếng Anh: target_lang = English
target_lang = Vietnamese
threads = 4

[display]
display_duration = 10
window_width = 800
window_height = 120

[transcription]
backend = mlx
whisper_model = base
funasr_model = iic/speech_paraformer-large_asr_nat-zh-cn-16k-common-vocab8404-pytorch
device = auto
compute_type = float16
# Nói tiếng Anh: source_language = en
source_language = auto
transcription_workers = 4

[audio]
device_index = auto
sample_rate = 16000
silence_threshold = 0.005
silence_duration = 0.5
chunk_duration = 0.1
max_phrase_duration = 30
streaming_mode = true
streaming_interval = 3
streaming_step_size = 0.2
update_interval = 0.8
streaming_overlap = 0.3
